@model MjerenjeDetailsViewModel

@{
    ViewData["Title"] = "Detalji mjerenja";
}

<style>
    /* ===== DETAIL PAGE LAYOUT ===== */
    .detail-header {
        margin-bottom: 32px;
    }

    .detail-header h1 {
        font-size: 28px;
        font-weight: 600;
        color: var(--color-text-primary);
        margin: 0 0 8px 0;
    }

    .detail-breadcrumb {
        font-size: 13px;
        color: var(--color-text-tertiary);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .detail-breadcrumb a {
        color: var(--color-primary-600);
        text-decoration: none;
        transition: color 0.2s;
    }

    .detail-breadcrumb a:hover {
        color: var(--color-primary-500);
    }

    /* ===== DETAIL CARD ===== */
    .detail-card {
        background: var(--color-surface-800);
        border: 1px solid var(--color-border-subtle);
        border-radius: 8px;
        padding: 32px;
        margin-bottom: 24px;
        box-shadow: var(--shadow-sm);
    }

    .detail-card-header {
        border-bottom: 1px solid var(--color-border-subtle);
        padding-bottom: 24px;
        margin-bottom: 24px;
    }

    .detail-card-header h2 {
        font-size: 20px;
        font-weight: 600;
        color: var(--color-text-primary);
        margin: 0;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* ===== METRICS GRID ===== */
    .metrics-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 24px;
        margin-bottom: 8px;
    }

    .metric-box {
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 16px;
        background: var(--color-surface-700);
        border-radius: 6px;
        border: 1px solid var(--color-border-subtle);
    }

    .metric-box-label {
        font-size: 11px;
        text-transform: uppercase;
        color: var(--color-text-tertiary);
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .metric-box-value {
        font-size: 28px;
        font-weight: 700;
        color: var(--color-text-primary);
        line-height: 1;
    }

    .metric-box-unit {
        font-size: 12px;
        color: var(--color-text-tertiary);
        font-weight: 500;
    }

    .metric-box.empty .metric-box-value {
        color: var(--color-text-disabled);
        font-style: italic;
        font-size: 14px;
        font-weight: 400;
    }

    /* ===== USER INFO SECTION ===== */
    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 0;
        border-bottom: 1px solid var(--color-border-subtle);
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-label {
        font-size: 13px;
        text-transform: uppercase;
        color: var(--color-text-tertiary);
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .info-value {
        font-size: 15px;
        color: var(--color-text-primary);
        font-weight: 500;
    }

    /* ===== ACTIONS ===== */
    .detail-actions {
        display: flex;
        gap: 12px;
        margin-top: 32px;
    }

    .action-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 20px;
        border-radius: 6px;
        text-decoration: none;
        font-size: 14px;
        font-weight: 600;
        transition: all 0.2s;
        border: 1px solid transparent;
        cursor: pointer;
        font-family: inherit;
    }

    .action-btn-primary {
        background-color: var(--color-primary-600);
        color: #111827;
        border-color: var(--color-primary-600);
    }

    .action-btn-primary:hover {
        background-color: var(--color-primary-500);
        border-color: var(--color-primary-500);
        box-shadow: var(--shadow-primary-md);
    }

    .action-btn-secondary {
        background-color: var(--color-surface-700);
        color: var(--color-text-primary);
        border: 1px solid var(--color-border-subtle);
    }

    .action-btn-secondary:hover {
        background-color: var(--color-surface-700);
        border-color: var(--color-border-default);
    }

    .action-btn:focus {
        outline: 3px solid var(--color-primary-600);
        outline-offset: 2px;
    }

    .action-icon {
        font-size: 16px;
    }

    /* ===== TREND CARD ===== */
    .trend-card {
        margin-top: 24px;
    }

    .trend-comparison {
        display: flex;
        justify-content: space-around;
        align-items: center;
        gap: 20px;
        padding: 20px 0;
    }

    .trend-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        flex: 1;
    }

    .trend-label {
        font-size: 11px;
        text-transform: uppercase;
        color: var(--color-text-tertiary);
        font-weight: 600;
    }

    .trend-previous,
    .trend-current {
        font-size: 24px;
        font-weight: 700;
        color: var(--color-text-primary);
    }

    .trend-date {
        font-size: 12px;
        color: var(--color-text-tertiary);
    }

    .trend-change {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
    }

    .trend-arrow-big {
        font-size: 40px;
        font-weight: 700;
    }

    .trend-up {
        color: var(--color-success-600);
    }

    .trend-down {
        color: var(--color-error-600);
    }

    .trend-neutral {
        color: var(--color-text-tertiary);
    }

    .change-amount {
        font-size: 18px;
        font-weight: 700;
        color: var(--color-text-primary);
    }

    .change-percent {
        font-size: 13px;
        color: var(--color-text-tertiary);
    }

    .change-label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        color: var(--color-text-tertiary);
        margin-top: 4px;
    }

    /* ===== STATS GRID ===== */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 16px;
        margin-top: 16px;
    }

    .stat-box {
        display: flex;
        flex-direction: column;
        gap: 8px;
        padding: 16px;
        background: var(--color-surface-700);
        border-radius: 6px;
        border: 1px solid var(--color-border-subtle);
        text-align: center;
    }

    .stat-label {
        font-size: 11px;
        text-transform: uppercase;
        color: var(--color-text-tertiary);
        font-weight: 600;
    }

    .stat-value {
        font-size: 24px;
        font-weight: 700;
        color: var(--color-text-primary);
    }

    .stat-unit {
        font-size: 12px;
        color: var(--color-text-tertiary);
    }

    /* ===== GOALS ===== */
    .goals-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .goal-item {
        padding: 16px;
        background: var(--color-surface-700);
        border-radius: 6px;
        border-left: 4px solid var(--color-border-subtle);
    }

    .goal-item.goal-active {
        border-left-color: var(--color-primary-600);
    }

    .goal-item.goal-achieved {
        border-left-color: var(--color-success-600);
        background: rgba(16, 185, 129, 0.05);
    }

    .goal-item.goal-overdue {
        border-left-color: var(--color-error-600);
        background: rgba(220, 38, 38, 0.05);
    }

    .goal-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 12px;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--color-border-subtle);
    }

    .goal-title {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .goal-title span {
        font-size: 12px;
        color: var(--color-text-tertiary);
        text-transform: uppercase;
        font-weight: 600;
    }

    .goal-title strong {
        font-size: 18px;
        color: var(--color-text-primary);
    }

    .goal-status {
        display: flex;
        gap: 8px;
    }

    .badge {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 12px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 600;
        white-space: nowrap;
    }

    .badge.active {
        background-color: rgba(16, 185, 129, 0.1);
        color: var(--color-success-600);
    }

    .badge.achieved {
        background-color: rgba(16, 185, 129, 0.1);
        color: var(--color-success-600);
    }

    .badge.overdue {
        background-color: rgba(220, 38, 38, 0.1);
        color: var(--color-error-600);
    }

    .badge.urgent {
        background-color: rgba(217, 119, 6, 0.1);
        color: var(--color-warning-600);
    }

    .goal-details {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .detail-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .detail-label {
        font-size: 12px;
        color: var(--color-text-tertiary);
        font-weight: 600;
        text-transform: uppercase;
    }

    .detail-value {
        font-size: 13px;
        color: var(--color-text-primary);
        font-weight: 500;
    }

    /* ===== RESPONSIVE ===== */
    @@media (max-width: 768px) {
        .trend-comparison {
            flex-direction: column;
            gap: 16px;
        }

        .stats-grid {
            grid-template-columns: 1fr 1fr;
        }

        .goal-header {
            flex-direction: column;
        }

        .detail-card {
            padding: 20px;
        }

        .metrics-grid {
            grid-template-columns: 1fr;
        }

        .detail-header h1 {
            font-size: 24px;
        }

        .detail-actions {
            flex-direction: column;
        }

        .action-btn {
            justify-content: center;
        }

        .info-row {
            flex-direction: column;
            align-items: flex-start;
            gap: 4px;
        }
    }
</style>

<!-- HEADER WITH BREADCRUMB -->
<div class="detail-header">
    <h1>Detalji mjerenja</h1>
    <div class="detail-breadcrumb">
        <a asp-action="Index">← Natrag na listu mjerenja</a>
    </div>
</div>

<!-- MAIN DETAIL CARD -->
<div class="detail-card">
    <!-- USER INFO SECTION -->
    <div class="detail-card-header">
        <h2>
            <span>📊</span>
            @(Model.Mjerenje.Korisnik is null ? $"Mjerenje #{Model.Mjerenje.Id}" : $"{Model.Mjerenje.Korisnik.Ime} {Model.Mjerenje.Korisnik.Prezime}")
        </h2>
    </div>

    <div class="info-row">
        <div class="info-label">Datum mjerenja</div>
        <div class="info-value">@Model.Mjerenje.DatumMjerenja.ToString("dd. MMMM yyyy.")</div>
    </div>

    @if (Model.Mjerenje.Korisnik is not null)
    {
        <div class="info-row">
            <div class="info-label">Korisnik</div>
            <div class="info-value">@Model.Mjerenje.Korisnik.Ime @Model.Mjerenje.Korisnik.Prezime</div>
        </div>
    }
</div>

<!-- TREND CARD (ako postoji prethodno mjerenje) -->
@if (!Model.IsFirstMeasurement && Model.PreviousMjerenje is not null)
{
    var trendClass = Model.TrendDirection == "up" ? "up" : (Model.TrendDirection == "down" ? "down" : "neutral");
    var trendArrow = Model.TrendDirection == "up" ? "↑" : (Model.TrendDirection == "down" ? "↓" : "→");
    var trendLabel = Model.TrendDirection == "up" ? "Povećano" : (Model.TrendDirection == "down" ? "Smanjeno" : "Stabilno");
    
    <div class="detail-card trend-card trend-@trendClass">
        <div class="detail-card-header">
            <h2>
                <span>📈</span>
                Trend od prethodnog mjerenja
            </h2>
        </div>

        <div class="trend-comparison">
            <div class="trend-item">
                <div class="trend-label">Prethodno mjerenje</div>
                <div class="trend-previous">@Model.PreviousMjerenje.Tezina.ToString("0.0") kg</div>
                <div class="trend-date">@Model.PreviousMjerenje.DatumMjerenja.ToString("dd. MMM yyyy.")</div>
            </div>

            <div class="trend-change">
                <div class="trend-arrow-big trend-@trendClass">@trendArrow</div>
                <div class="change-amount">@Model.WeightChange?.ToString("+0.0;-0.0") kg</div>
                <div class="change-percent">(@Model.PercentageChange?.ToString("+0.0;-0.0")%)</div>
                <div class="change-label">@trendLabel</div>
            </div>

            <div class="trend-item">
                <div class="trend-label">Trenutno mjerenje</div>
                <div class="trend-current">@Model.Mjerenje.Tezina.ToString("0.0") kg</div>
                <div class="trend-date">@Model.Mjerenje.DatumMjerenja.ToString("dd. MMM yyyy.")</div>
            </div>
        </div>
    </div>
}

<!-- YEARLY STATISTICS CARD -->
@if (Model.TotalMeasurementsThisYear > 0)
{
    <div class="detail-card stats-card">
        <div class="detail-card-header">
            <h2>
                <span>📊</span>
                Statistika ove godine (@DateTime.Now.Year)
            </h2>
        </div>

        <div class="stats-grid">
            <div class="stat-box">
                <div class="stat-label">Ukupno mjerenja</div>
                <div class="stat-value">@Model.TotalMeasurementsThisYear</div>
            </div>

            <div class="stat-box">
                <div class="stat-label">Najniža težina</div>
                <div class="stat-value">@Model.LowestWeight?.ToString("0.0")</div>
                <div class="stat-unit">kg</div>
            </div>

            <div class="stat-box">
                <div class="stat-label">Najveća težina</div>
                <div class="stat-value">@Model.HighestWeight?.ToString("0.0")</div>
                <div class="stat-unit">kg</div>
            </div>

            <div class="stat-box">
                <div class="stat-label">Prosječna težina</div>
                <div class="stat-value">@Model.AverageWeight?.ToString("0.0")</div>
                <div class="stat-unit">kg</div>
            </div>
        </div>
    </div>
}

<!-- GOALS CARD (ako postoje relevantni ciljevi) -->
@if (Model.RelevantGoals.Count > 0)
{
    <div class="detail-card goals-card">
        <div class="detail-card-header">
            <h2>
                <span>🎯</span>
                Tvoji ciljevi
            </h2>
        </div>

        <div class="goals-list">
            @foreach (var goal in Model.RelevantGoals)
            {
                var daysLeft = (goal.Rok - DateTime.Now).TotalDays;
                var statusClass = goal.Postignut ? "achieved" : (daysLeft < 0 ? "overdue" : "active");
                
                <div class="goal-item goal-@statusClass">
                    <div class="goal-header">
                        <div class="goal-title">
                            @if (goal.Tip == TipCilja.Mrsavljenje) {
                                <span>Ciljna težina:</span>
                            } else if (goal.Tip == TipCilja.DobivanjeMase) {
                                <span>Ciljna masa:</span>
                            }
                            <strong>@goal.CiljanaVrijednost.ToString("0.0") kg</strong>
                        </div>
                        <div class="goal-status">
                            @if (goal.Postignut) {
                                <span class="badge achieved">✓ Ostvareno</span>
                            } else if (daysLeft < 0) {
                                <span class="badge overdue">⚠ Prekoračeno</span>
                            } else if (daysLeft < 7) {
                                <span class="badge urgent">🔥 Hitno</span>
                            } else {
                                <span class="badge active">→ Aktivno</span>
                            }
                        </div>
                    </div>

                    <div class="goal-details">
                        <div class="detail-row">
                            <div class="detail-label">Rok:</div>
                            <div class="detail-value">@goal.Rok.ToString("dd. MMM yyyy.")</div>
                        </div>
                        <div class="detail-row">
                            <div class="detail-label">Preostalo:</div>
                            <div class="detail-value">
                                @if (daysLeft >= 0) {
                                    <span>@Math.Ceiling(daysLeft) dana</span>
                                } else {
                                    <span>@Math.Abs(Math.Ceiling(daysLeft)) dana kašnjenja</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}
</div>

<!-- MEASUREMENTS METRICS CARD -->
<div class="detail-card">
    <div class="detail-card-header">
        <h2>
            <span>📏</span>
            Mjerenja
        </h2>
    </div>

    <div class="metrics-grid">
        <!-- PRIMARY: WEIGHT -->
        <div class="metric-box">
            <div class="metric-box-label">Težina</div>
            <div class="metric-box-value">@Model.Mjerenje.Tezina.ToString("0.0")</div>
            <div class="metric-box-unit">kg</div>
        </div>

        <!-- BODY FAT PERCENTAGE -->
        <div class="metric-box @(Model.Mjerenje.PostotakMasti == null ? "empty" : "")">
            <div class="metric-box-label">% Masti</div>
            <div class="metric-box-value">
                @if (Model.Mjerenje.PostotakMasti.HasValue)
                {
                    @Model.Mjerenje.PostotakMasti.Value.ToString("0.0")
                }
                else
                {
                    <span>—</span>
                }
            </div>
            @if (Model.Mjerenje.PostotakMasti.HasValue)
            {
                <div class="metric-box-unit">Body Fat %</div>
            }
        </div>

        <!-- WAIST CIRCUMFERENCE -->
        <div class="metric-box @(Model.Mjerenje.OpsegStruka == null ? "empty" : "")">
            <div class="metric-box-label">Opseg struka</div>
            <div class="metric-box-value">
                @if (Model.Mjerenje.OpsegStruka.HasValue)
                {
                    @Model.Mjerenje.OpsegStruka.Value.ToString("0.0")
                }
                else
                {
                    <span>—</span>
                }
            </div>
            @if (Model.Mjerenje.OpsegStruka.HasValue)
            {
                <div class="metric-box-unit">cm</div>
            }
        </div>
    </div>
</div>

<!-- ACTIONS -->
<div class="detail-actions">
    <a asp-action="Index" class="action-btn action-btn-secondary">
        <span class="action-icon">←</span>
        Natrag
    </a>
</div>

