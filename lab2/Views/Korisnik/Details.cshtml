@model Korisnik

@{
    ViewData["Title"] = $"Detalji korisnika - {Model.Ime} {Model.Prezime}";
    var age = DateTime.Now.Year - Model.DatumRodjenja.Year;
    var bmi = Model.Tezina / ((Model.Visina / 100) * (Model.Visina / 100));
    var bmiCategory = bmi < 18.5 ? "Nedovoljna težina" : (bmi < 25 ? "Normalna težina" : (bmi < 30 ? "Prekomjerna težina" : "Pretilost"));
    var bmiColor = bmi < 18.5 ? "#3b82f6" : (bmi < 25 ? "#10b981" : (bmi < 30 ? "#f59e0b" : "#ef4444"));
    var registrationDays = (DateTime.Now - Model.DatumRegistracije).Days;
}

<style>
    .user-hero {
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.15) 0%, rgba(59, 130, 246, 0.05) 100%);
        border: 1px solid rgba(59, 130, 246, 0.3);
        border-radius: 16px;
        padding: 48px 32px;
        margin-bottom: 40px;
        position: relative;
        overflow: hidden;
    }

    .user-hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(59, 130, 246, 0.1) 0%, transparent 70%);
        border-radius: 50%;
    }

    .user-hero-content {
        position: relative;
        z-index: 1;
    }

    .user-avatar {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        margin-bottom: 16px;
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.2);
    }

    .user-specs-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 16px;
        margin-bottom: 32px;
    }

    .user-spec-card {
        background: var(--color-surface-800);
        border: 1px solid var(--color-border-subtle);
        border-radius: 8px;
        padding: 20px;
        text-align: center;
    }

    .user-spec-label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--color-text-tertiary);
        margin-bottom: 8px;
    }

    .user-spec-value {
        font-size: 24px;
        font-weight: 700;
        color: var(--color-primary-600);
    }

    .back-nav {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        background: rgba(59, 130, 246, 0.1);
        border: 1px solid rgba(59, 130, 246, 0.3);
        border-radius: 6px;
        color: #3b82f6;
        text-decoration: none;
        font-weight: 500;
        font-size: 14px;
        margin-bottom: 32px;
        transition: all 0.2s;
    }

    .back-nav:hover {
        background: rgba(59, 130, 246, 0.2);
        border-color: rgba(59, 130, 246, 0.5);
    }

    .info-section {
        background: var(--color-surface-800);
        border: 1px solid var(--color-border-subtle);
        border-radius: 12px;
        padding: 28px;
        margin-bottom: 40px;
        border-left: 4px solid #3b82f6;
    }

    .info-section h2 {
        margin: 0 0 16px 0;
        font-size: 18px;
        font-weight: 700;
        color: var(--color-text-primary);
    }

    .info-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 0;
        border-bottom: 1px solid var(--color-border-subtle);
    }

    .info-item:last-child {
        border-bottom: none;
    }

    .info-label {
        font-size: 14px;
        font-weight: 600;
        color: var(--color-text-secondary);
    }

    .info-value {
        font-size: 15px;
        font-weight: 600;
        color: var(--color-text-primary);
    }

    .related-section {
        margin-bottom: 40px;
    }

    .related-title {
        font-size: 18px;
        font-weight: 700;
        color: var(--color-text-primary);
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .related-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 16px;
    }

    .related-card {
        background: var(--color-surface-800);
        border: 1px solid var(--color-border-subtle);
        border-radius: 8px;
        padding: 16px;
        transition: all 0.2s;
    }

    .related-card:hover {
        border-color: var(--color-primary-500);
        background: var(--color-surface-700);
    }

    .related-label {
        font-size: 12px;
        text-transform: uppercase;
        color: var(--color-text-tertiary);
        font-weight: 600;
        margin-bottom: 8px;
    }

    .related-value {
        font-size: 16px;
        font-weight: 600;
        color: var(--color-text-primary);
    }

    .empty-state-mini {
        text-align: center;
        padding: 24px;
        background: var(--color-surface-800);
        border: 1px dashed var(--color-border-subtle);
        border-radius: 8px;
        color: var(--color-text-tertiary);
    }
</style>

<!-- BACK BUTTON -->
<a asp-action="Index" class="back-nav">
    <i class="fas fa-arrow-left"></i>
    Natrag na listu korisnika
</a>

<!-- HERO SECTION -->
<div class="user-hero">
    <div class="user-hero-content">
        <div class="user-avatar">👤</div>
        <h1 style="margin: 0 0 8px 0; font-size: 42px; font-weight: 800; color: var(--color-text-primary); line-height: 1.1;">
            @Model.Ime @Model.Prezime
        </h1>
        <p style="margin: 0; font-size: 16px; color: var(--color-text-secondary);">
            ✉️ @Model.Email
        </p>
    </div>
</div>

<!-- KEY INFORMATION -->
<div class="info-section">
    <h2>ℹ️ Osnovne Informacije</h2>
    <div class="info-item">
        <span class="info-label">Datum rođenja:</span>
        <span class="info-value">@Model.DatumRodjenja.ToString("dd.MM.yyyy.") (@age godina)</span>
    </div>
    <div class="info-item">
        <span class="info-label">Datum registracije:</span>
        <span class="info-value">@Model.DatumRegistracije.ToString("dd.MM.yyyy.") (@registrationDays dana)</span>
    </div>
    <div class="info-item">
        <span class="info-label">Email:</span>
        <span class="info-value" style="word-break: break-all;">@Model.Email</span>
    </div>
    <div class="info-item">
        <span class="info-label">Trenutni plan:</span>
        <span class="info-value">@(Model.TrenutniPlan?.Naziv ?? "Nije odabran")</span>
    </div>
</div>

<!-- PHYSICAL SPECS GRID -->
<div class="user-specs-grid">
    <div class="user-spec-card">
        <div class="user-spec-label">
            <i class="fas fa-ruler-vertical"></i> Visina
        </div>
        <div class="user-spec-value">@Model.Visina.ToString("F0")</div>
        <p style="margin: 8px 0 0; font-size: 12px; color: var(--color-text-tertiary);">cm</p>
    </div>

    <div class="user-spec-card">
        <div class="user-spec-label">
            <i class="fas fa-weight"></i> Težina
        </div>
        <div class="user-spec-value">@Model.Tezina.ToString("F1")</div>
        <p style="margin: 8px 0 0; font-size: 12px; color: var(--color-text-tertiary);">kg</p>
    </div>

    <div class="user-spec-card">
        <div class="user-spec-label">
            <i class="fas fa-heartbeat"></i> BMI
        </div>
        <div class="user-spec-value" style="color: @bmiColor;">@bmi.ToString("F1")</div>
        <p style="margin: 8px 0 0; font-size: 12px; color: var(--color-text-tertiary);">@bmiCategory</p>
    </div>
</div>

<!-- STATISTICS -->
<div class="user-specs-grid">
    <div class="user-spec-card">
        <div class="user-spec-label">
            <i class="fas fa-dumbbell"></i> Treninzi
        </div>
        <div class="user-spec-value">@Model.Treninzi.Count</div>
        <p style="margin: 8px 0 0; font-size: 12px; color: var(--color-text-tertiary);">ukupno</p>
    </div>

    <div class="user-spec-card">
        <div class="user-spec-label">
            <i class="fas fa-bullseye"></i> Ciljevi
        </div>
        <div class="user-spec-value">@Model.Ciljevi.Count</div>
        <p style="margin: 8px 0 0; font-size: 12px; color: var(--color-text-tertiary);">postavljenih</p>
    </div>

    <div class="user-spec-card">
        <div class="user-spec-label">
            <i class="fas fa-chart-line"></i> Mjerenja
        </div>
        <div class="user-spec-value">@Model.Mjerenja.Count</div>
        <p style="margin: 8px 0 0; font-size: 12px; color: var(--color-text-tertiary);">izvršenih</p>
    </div>
</div>

<!-- GOALS SECTION -->
@if (Model.Ciljevi.Any())
{
    <div class="related-section">
        <h2 class="related-title">
            <i class="fas fa-bullseye"></i> Ciljevi Korisnika (@Model.Ciljevi.Count)
        </h2>
        <div class="related-grid">
            @foreach (var goal in Model.Ciljevi)
            {
                <div class="related-card">
                    <div class="related-label">Tip cilja</div>
                    <div class="related-value">@goal.Tip</div>
                    <div class="related-label" style="margin-top: 12px;">Ciljana vrijednost</div>
                    <div class="related-value">@goal.CiljanaVrijednost</div>
                    <div style="margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--color-border-subtle); font-size: 12px;">
                        @if (goal.Postignut)
                        {
                            <span style="color: #10b981;">✓ Postignut</span>
                        }
                        else
                        {
                            <span style="color: #f59e0b;">⏳ Čekajući</span>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- BACK BUTTON AT BOTTOM -->
<div style="margin-top: 40px;">
    <a asp-action="Index" class="back-nav">
        <i class="fas fa-arrow-left"></i>
        Natrag na listu korisnika
    </a>
</div>
