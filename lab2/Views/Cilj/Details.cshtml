@model Cilj

@{
    ViewData["Title"] = $"Detalji cilja - {Model.Tip}";
    var statusClass = Model.Postignut ? "completed" : "pending";
    var statusText = Model.Postignut ? "Postignut" : "Čekajući";
    var statusIcon = Model.Postignut ? "✓" : "⏳";
    var userName = Model.Korisnik is null ? $"Korisnik {Model.KorisnikId}" : $"{Model.Korisnik.Ime} {Model.Korisnik.Prezime}";
    var daysUntilDeadline = (Model.Rok - DateTime.Now).Days;
    var deadlineStatus = Model.Postignut ? "Postignut" : (daysUntilDeadline < 0 ? "Rok je prošao" : (daysUntilDeadline == 0 ? "Završava se danas" : $"Još {daysUntilDeadline} dana"));
}

<style>
    .goal-hero {
        background: linear-gradient(135deg, rgba(16, 185, 129, 0.15) 0%, rgba(16, 185, 129, 0.05) 100%);
        border: 1px solid rgba(16, 185, 129, 0.3);
        border-radius: 16px;
        padding: 48px 32px;
        margin-bottom: 40px;
        position: relative;
        overflow: hidden;
    }

    .goal-hero::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(16, 185, 129, 0.1) 0%, transparent 70%);
        border-radius: 50%;
    }

    .goal-hero-content {
        position: relative;
        z-index: 1;
    }

    .goal-specs-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 16px;
        margin-bottom: 32px;
    }

    .goal-spec-card {
        background: var(--color-surface-800);
        border: 1px solid var(--color-border-subtle);
        border-radius: 8px;
        padding: 20px;
        text-align: center;
    }

    .goal-spec-label {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--color-text-tertiary);
        margin-bottom: 8px;
    }

    .goal-spec-value {
        font-size: 24px;
        font-weight: 700;
        color: var(--color-primary-600);
    }

    .back-nav {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        background: rgba(16, 185, 129, 0.1);
        border: 1px solid rgba(16, 185, 129, 0.3);
        border-radius: 6px;
        color: #10b981;
        text-decoration: none;
        font-weight: 500;
        font-size: 14px;
        margin-bottom: 32px;
        transition: all 0.2s;
    }

    .back-nav:hover {
        background: rgba(16, 185, 129, 0.2);
        border-color: rgba(16, 185, 129, 0.5);
    }

    .goal-status-large {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 20px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 16px;
        margin-top: 16px;
    }

    .goal-status-large.completed {
        background-color: rgba(16, 185, 129, 0.2);
        color: #10b981;
    }

    .goal-status-large.pending {
        background-color: rgba(245, 158, 11, 0.2);
        color: #f59e0b;
    }

    .info-section {
        background: var(--color-surface-800);
        border: 1px solid var(--color-border-subtle);
        border-radius: 12px;
        padding: 28px;
        margin-bottom: 40px;
        border-left: 4px solid var(--color-primary-600);
    }

    .info-section h2 {
        margin: 0 0 16px 0;
        font-size: 18px;
        font-weight: 700;
        color: var(--color-text-primary);
    }

    .info-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 0;
        border-bottom: 1px solid var(--color-border-subtle);
    }

    .info-item:last-child {
        border-bottom: none;
    }

    .info-label {
        font-size: 14px;
        font-weight: 600;
        color: var(--color-text-secondary);
    }

    .info-value {
        font-size: 15px;
        font-weight: 600;
        color: var(--color-text-primary);
    }
</style>

<!-- BACK BUTTON -->
<a asp-action="Index" class="back-nav">
    <i class="fas fa-arrow-left"></i>
    Natrag na listu ciljeva
</a>

<!-- HERO SECTION -->
<div class="goal-hero">
    <div class="goal-hero-content">
        <h1 style="margin: 0 0 16px 0; font-size: 42px; font-weight: 800; color: var(--color-text-primary); line-height: 1.1;">
            @Model.Tip
        </h1>

        <!-- USER AND STATUS -->
        <div style="display: flex; align-items: center; gap: 24px; margin-bottom: 24px; flex-wrap: wrap;">
            <div>
                <p style="margin: 0 0 4px 0; font-size: 12px; text-transform: uppercase; color: var(--color-text-tertiary); letter-spacing: 0.5px;">
                    Korisnik
                </p>
                <p style="margin: 0; font-size: 16px; font-weight: 700; color: var(--color-text-primary);">
                    👤 @userName
                </p>
            </div>
            <div style="border-left: 2px solid rgba(255,255,255,0.2); padding-left: 24px;">
                <p style="margin: 0 0 4px 0; font-size: 12px; text-transform: uppercase; color: var(--color-text-tertiary); letter-spacing: 0.5px;">
                    Status
                </p>
                <div class="goal-status-large @statusClass">
                    @statusIcon @statusText
                </div>
            </div>
        </div>
    </div>
</div>

<!-- KEY INFORMATION -->
<div class="info-section">
    <h2>ℹ️ Osnovne Informacije</h2>
    <div class="info-item">
        <span class="info-label">Ciljana Vrijednost:</span>
        <span class="info-value">@Model.CiljanaVrijednost</span>
    </div>
    <div class="info-item">
        <span class="info-label">Rok:</span>
        <span class="info-value">@Model.Rok.ToString("dd.MM.yyyy.")</span>
    </div>
    <div class="info-item">
        <span class="info-label">Preostalo vrijeme:</span>
        <span class="info-value" style="color: @(daysUntilDeadline < 0 ? "#ef4444" : (daysUntilDeadline < 7 ? "#f59e0b" : "#10b981"));">
            @deadlineStatus
        </span>
    </div>
    <div class="info-item">
        <span class="info-label">Status:</span>
        <span class="info-value">
            @if (Model.Postignut)
            {
                <span style="color: #10b981;">✓ Postignut</span>
            }
            else
            {
                <span style="color: #f59e0b;">⏳ Čekajući</span>
            }
        </span>
    </div>
</div>

<!-- SPECS GRID -->
<div class="goal-specs-grid">
    <div class="goal-spec-card">
        <div class="goal-spec-label">
            <i class="fas fa-bullseye"></i> Cilj
        </div>
        <div class="goal-spec-value">@Model.CiljanaVrijednost</div>
        <p style="margin: 8px 0 0; font-size: 12px; color: var(--color-text-tertiary);">Ciljana vrijednost</p>
    </div>

    <div class="goal-spec-card">
        <div class="goal-spec-label">
            <i class="fas fa-calendar"></i> Rok
        </div>
        <div class="goal-spec-value" style="font-size: 18px;">@Model.Rok.ToString("dd")</div>
        <p style="margin: 8px 0 0; font-size: 12px; color: var(--color-text-tertiary);">@Model.Rok.ToString("MMM yyyy")</p>
    </div>

    <div class="goal-spec-card">
        <div class="goal-spec-label">
            <i class="fas fa-check-circle"></i> Status
        </div>
        <div class="goal-spec-value" style="font-size: 20px; color: @(Model.Postignut ? "#10b981" : "#f59e0b");">
            @(Model.Postignut ? "✓" : "⏳")
        </div>
        <p style="margin: 8px 0 0; font-size: 12px; color: var(--color-text-tertiary);">@statusText</p>
    </div>
</div>

<!-- BACK BUTTON AT BOTTOM -->
<div style="margin-top: 40px;">
    <a asp-action="Index" class="back-nav">
        <i class="fas fa-arrow-left"></i>
        Natrag na listu ciljeva
    </a>
</div>
